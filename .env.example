# KG Extractor 环境变量配置

# LLM API 配置
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
OPENAI_MODEL=glm-4.5

# Embedding 模型配置（用于 entity_dedup 等脚本）
# 默认使用本地 Ollama qwen3-embedding 模型
OPENAI_EMBED_BASE_URL=http://localhost:11434/api
OPENAI_EMBED_MODEL=qwen3-embedding

# 知识图谱目录 (可选，默认使用 ontology/)
KG_DIR=ontology/

# 全局 KG 路径 (可选，用于生产环境)
# KG_DIR=/root/.openclaw/workspace/memory/ontology

# Agents 会话目录 (生产环境)
# KG 提取器从该目录下所有 sessions/ 子目录中读取 *.jsonl 文件
KG_AGENTS_DIR=agents/
