# === Chat LLM ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-5

# === Embedding ===
# Default: Ollama qwen3-embedding (local, no key needed)
OPENAI_EMBED_BASE_URL=http://localhost:11434/api
OPENAI_EMBED_MODEL=qwen3-embedding

# === MiniMax API (Reader + Evaluator) ===
MINIMAX_API_KEY=
# Base URL: MiniMax Chat Completions API (wire_api=chat)
# LLMClient auto-detects Anthropic path for Reader, OpenAI path for Evaluator

# === Reader (eval pipeline) ===
# Uses MiniMax Anthropic endpoint: base_url + /anthropic/v1
READER_BASE_URL=https://api.minimaxi.com/anthropic/v1
READER_MODEL=MiniMax-M2.7-highspeed

# === Evaluator (LLM judge) ===
# Uses MiniMax native Chat Completions: base_url + /chat/completions
EVAL_BASE_URL=https://api.minimaxi.com/v1
EVAL_MODEL=MiniMax-M2.7

# === Knowledge Graph ===
# KG_DIR=ontology/
# KG_AGENTS_DIR=agents/
