{"op": "create", "entity": {"id": "find_reminder_script_issue", "type": "Finding", "properties": {"title": "提醒脚本数据源错误", "finding": "每日进化提醒脚本读取 MEMORY.md 而非日记忆文件，导致提醒内容不更新", "found_at": "2026-03-17T19:50:00+08:00", "context": "21:00 提醒内容未更新", "source": "提醒脚本检查", "root_cause": "数据源错误：MEMORY.md（无今日数据）而非 memory/YYYY-MM-DD.md", "solution": "修改 parseDailyMemoryTasks() 函数读取正确的日记忆文件", "tags": ["#finding", "#reminder", "#bug-fix", "#automation"]}, "created": "2026-03-17T23:54:09+08:00", "updated": "2026-03-17T23:54:09+08:00"}, "timestamp": "2026-03-17T23:54:09+08:00"}
