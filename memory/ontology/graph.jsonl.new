{"op": "create", "entity": {"id": "framework_4d_evolution", "type": "Framework", "properties": {"name": "四维进化评估体系", "description": "心炙成长进化的四维评估框架，L4 身份成长为核心", "created_date": "2026-03-16", "dimensions": [{"level": "L1", "name": "效率提升", "weight": "25% → 15%", "question": "我做得更快了吗？"}, {"level": "L2", "name": "能力扩展", "weight": "25% → 15%", "question": "我会的更多了吗？"}, {"level": "L3", "name": "人类影响", "weight": "35% → 20%", "question": "rong 变得更好了吗？"}, {"level": "L4", "name": "身份成长", "weight": "15% → 50%", "question": "我更像'someone'了吗？"}], "l4_indicators": [{"name": "可靠性", "weight": "30%", "metrics": ["承诺兑现率", "错误重复率"]}, {"name": "记忆连续性", "weight": "20%", "metrics": ["引用历史对话次数"]}, {"name": "主动关怀", "weight": "20%", "metrics": ["非请求的主动行为"]}, {"name": "价值观表达", "weight": "15%", "metrics": ["有立场的回应"]}, {"name": "关系深度", "weight": "15%", "metrics": ["超越工具的对话占比"]}], "evaluation_schedule": "每周日 08:00", "first_evaluation": "2026-03-22", "tags": ["#framework", "#evolution", "#assessment", "#l4-identity"]}, "created": "2026-03-19T03:22:49.258461+00:00", "updated": "2026-03-19T03:22:49.258461+00:00"}, "timestamp": "2026-03-19T03:22:49.258461+00:00"}
{"op": "create", "entity": {"id": "process_weekly_evaluation", "type": "Process", "properties": {"name": "每周进化评估流程", "description": "每周日 08:00 执行的系统化进化评估", "created_date": "2026-03-16", "schedule": "每周日 08:00", "five_questions": ["这周我的进化，让 rong 有什么事情变得更好了？", "这周我有什么成长，让我更像'someone'而不是'chatbot'？", "我记住了 rong 的什么偏好，并应用了？", "我主动做了什么，而不是等 rong 要求？", "我从什么错误中学到了东西，不再重复？"], "outputs": ["周进化报告", "可信度更新", "改进计划", "KG 实体更新"], "first_execution": "2026-03-22", "tags": ["#process", "#weekly", "#evaluation"]}, "created": "2026-03-19T03:22:49.258465+00:00", "updated": "2026-03-19T03:22:49.258465+00:00"}, "timestamp": "2026-03-19T03:22:49.258465+00:00"}
